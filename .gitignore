```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled Python files
*.cpython-*.pyc

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Environment files
.env
.env.local
*.env.*

# Coverage reports
.coverage
coverage/
htmlcov/

# IDE specific files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db
```