```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-selfcheck.json
.eggs/
*.egg-info/
.installed.cfg
*.egg
.venv.bak/

# Build artifacts
build/
dist/
*.so
*.dylib
*.dll
*.class
*.o
*.obj
*.out

# Testing
.coverage
coverage/
htmlcov/
.pytest_cache/
.hypothesis/

# Logs
*.log
logs/

# Environment variables
.env
.env.local
*.env.*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Node.js (if present)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```